# Copy this file to .env.local for local development
# In Vercel: add these as Environment Variables in the project settings

# N8N backend URL (same as Worker's N8N_BASE_URL)
N8N_BASE_URL=https://n8n.oriamind.ai

# N8N site token - keeps the secret server-side (same as Worker's N8N_SITE_TOKEN)
N8N_SITE_TOKEN=your_secret_token_here

# Public site URL — used to build Morning payment callbacks (notifyUrl, successUrl, failureUrl)
# Must be the canonical production URL. Falls back to request Host header if not set.
SITE_URL=https://oria.ai

# Morning (Green Invoice) credentials — set these in Vercel environment variables
# Never expose these to the browser. Used server-side only in /api/initiate-payment.
MORNING_API_ID=c666788d-9fe1-4910-b871-7c94caf69242
MORNING_API_SECRET=)!{2NiXr.[8MN|OIc5!XGl@E0?@&hFh?
# Sandbox:    https://sandbox.greeninvoice.co.il/api/v1
# Production: https://api.greeninvoice.co.il/api/v1  (default if not set)
MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1
